# ─── Receipt Helper Environment Variables ───
# Copy this to .env and fill in real values.

# MiniMax API Key (for OCR)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_MODEL=MiniMax-M2.5

# Google Cloud Service Account JSON key file path
# (relative to backend/ or absolute path)
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# Google Drive — Root folder ID (from the folder URL)
# e.g. https://drive.google.com/drive/folders/THIS_PART
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_drive_folder_id

# Google Sheets — Spreadsheet ID (from the sheet URL)
# e.g. https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id

# CORS origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
